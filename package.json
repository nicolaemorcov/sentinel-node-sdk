{
  "name": "strictloop-node-sdk",
  "version": "1.0.1",
  "description": "StrictLoop AI exception monitoring SDK for Node.js / TypeScript applications",
  "keywords": ["strictloop", "monitoring", "exception", "ai", "typescript", "nodejs"],
  "license": "MIT",
  "engines": {
    "node": ">=18.3.0"
  },
  "main":   "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types":  "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "import":  "./dist/esm/index.js",
      "require": "./dist/cjs/index.js",
      "types":   "./dist/types/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build":       "npm run build:cjs && npm run build:esm && npm run build:types",
    "build:cjs":   "tsc --project tsconfig.cjs.json",
    "build:esm":   "tsc --project tsconfig.build.json --module NodeNext --outDir dist/esm",
    "build:types": "tsc --project tsconfig.build.json --declaration --declarationMap --emitDeclarationOnly --outDir dist/types",
    "typecheck":   "tsc --noEmit",
    "lint":        "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {},
  "peerDependencies": {
    "express": ">=4.0.0",
    "next":    ">=13.0.0"
  },
  "peerDependenciesMeta": {
    "express": { "optional": true },
    "next":    { "optional": true }
  },
  "devDependencies": {
    "@types/express": "^4.17.0",
    "@types/node":    "^18.0.0",
    "typescript":     "^5.4.0"
  }
}
